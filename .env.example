# Supabase — projeto ScaleDent
# Copie este arquivo para .env.local e preencha com as chaves do seu projeto.
# Supabase → Project Settings → Data API / API Keys
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...sua_anon_key

# Secreta — só no servidor. Necessária para o painel admin criar usuários.
SUPABASE_SERVICE_ROLE_KEY=eyJ...sua_service_role_key
